{
  "expo": {
    "name": "Receipto",
    "slug": "receipto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "receipto",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.receipto.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "de.receipto.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Receipto benötigt Kamerazugriff um Kassenbons zu scannen."
        }
      ],
      "expo-localization",
      "expo-mail-composer",
      "@sentry/react-native",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
